generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  APROBADOR
  CONTRATISTA
}

enum EstadoEntregable {
  PENDIENTE
  EN_REVISION
  APROBADO
  RECHAZADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  FALLIDO
}

model Empresa {
  id                 String              @id @default(cuid())
  nombre             String
  nit                String              @unique
  createdAt          DateTime            @default(now())
  usuarios           Usuario[]
  contratos          Contrato[]
  configPenalizacion ConfigPenalizacion?
  tarifasRetencion   TarifaRetencion[]
  plantillas  PlantillaContrato[]
}

model ConfigPenalizacion {
  id               String   @id @default(cuid())
  empresaId        String   @unique
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  porcentajePorDia Int      @default(2)
  topeMaximo       Int      @default(20)
  bonoPorDia       Int      @default(1)
  topeBonoMaximo   Int      @default(10)
  updatedAt        DateTime @updatedAt
}

model TarifaRetencion {
  id          String   @id @default(cuid())
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  desde       Int
  hasta       Int?
  porcentaje  Int
  orden       Int
  createdAt   DateTime @default(now())

  @@index([empresaId, orden])
}

model Usuario {
  id             String      @id @default(cuid())
  nombre         String
  email          String      @unique
  password       String
  rol            Rol
  empresaId      String
  empresa        Empresa     @relation(fields: [empresaId], references: [id])
  ivaResponsable Boolean     @default(false) // si cobra IVA 19% en sus honorarios
  createdAt      DateTime    @default(now())
  contratos      Contrato[]  @relation("Contratista")
  evidencias     Evidencia[]
  actasFirmadas  Acta[]      @relation("Aprobador")
  rubricas     Rubrica[]
  auditoria    AuditoriaLog[]
}

model Contrato {
  id                  String       @id @default(cuid())
  titulo              String
  descripcion         String?
  valorTotal          Int
  fechaInicio         DateTime
  fechaFin            DateTime
  empresaId           String
  empresa             Empresa      @relation(fields: [empresaId], references: [id])
  contratistaId       String
  contratista         Usuario      @relation("Contratista", fields: [contratistaId], references: [id])
  retencionPorcentaje Int          @default(0)
  createdAt           DateTime     @default(now())
  entregables         Entregable[]
}

model Entregable {
  id           String           @id @default(cuid())
  nombre       String
  descripcion  String?
  valor        Int
  fechaLimite  DateTime
  estado       EstadoEntregable @default(PENDIENTE)
  penalizacion Int              @default(0)
  diasRetraso  Int              @default(0)
  contratoId   String
  contrato     Contrato         @relation(fields: [contratoId], references: [id])
  createdAt    DateTime         @default(now())
  evidencias   Evidencia[]
  acta         Acta?
  pago         Pago?
  rubrica      Rubrica?
}

model Evidencia {
  id           String     @id @default(cuid())
  nombre       String
  url          String
  entregableId String
  entregable   Entregable @relation(fields: [entregableId], references: [id])
  subidoPorId  String
  subidoPor    Usuario    @relation(fields: [subidoPorId], references: [id])
  createdAt    DateTime   @default(now())
}

model Acta {
  id               String     @id @default(cuid())
  entregableId     String     @unique
  entregable       Entregable @relation(fields: [entregableId], references: [id])
  firmaContratista DateTime?
  firmaAprobador   DateTime?
  aprobadorId      String?
  aprobador        Usuario?   @relation("Aprobador", fields: [aprobadorId], references: [id])
  pdfUrl           String?
  comentario       String?
  createdAt        DateTime   @default(now())
}

model Pago {
  id           String     @id @default(cuid())
  entregableId String     @unique
  entregable   Entregable @relation(fields: [entregableId], references: [id])
  valor        Int        // valor base después de penalización/bono
  iva          Int        @default(0) // IVA 19% si el contratista es responsable
  retencion    Int        @default(0)
  valorNeto    Int        @default(0) // lo que recibe el contratista
  estado       EstadoPago @default(PENDIENTE)
  fecha        DateTime?
  createdAt    DateTime   @default(now())
}

model Rubrica {
  id            String      @id @default(cuid())
  entregableId  String      @unique
  entregable    Entregable  @relation(fields: [entregableId], references: [id])
  completitud   Int         // 1-5
  puntualidad   Int         // 1-5
  calidad       Int         // 1-5
  comentario    String?
  creadoPorId   String
  creadoPor     Usuario     @relation(fields: [creadoPorId], references: [id])
  creadoEn      DateTime    @default(now())
}

model AuditoriaLog {
  id          String    @id @default(cuid())
  usuarioId   String
  usuario     Usuario   @relation(fields: [usuarioId], references: [id])
  accion      String    // "APROBAR_ENTREGABLE" | "RECHAZAR_ENTREGABLE" | "CREAR_CONTRATO" | etc.
  entidad     String    // "Entregable" | "Contrato" | "Usuario" | etc.
  entidadId   String
  detalle     Json?     // datos extra: valores anteriores, nuevos, etc.
  ip          String?
  creadoEn    DateTime  @default(now())

  @@index([usuarioId])
  @@index([accion])
  @@index([creadoEn])
}

model PlantillaContrato {
  id             String   @id @default(cuid())
  titulo         String
  descripcion    String?
  valorSugerido  Int?
  empresaId      String
  empresa        Empresa  @relation(fields: [empresaId], references: [id])
  entregables    Json     // [{nombre, descripcion, valor, diasPlazo}]
  creadoEn       DateTime @default(now())

  @@index([empresaId])
}